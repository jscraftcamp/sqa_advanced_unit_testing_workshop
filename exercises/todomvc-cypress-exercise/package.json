{
  "name": "todomvc-react-hooks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blacksonic/todomvc-react-hooks.git"
  },
  "scripts": {
    "start": "PORT=9300 BROWSER=none react-scripts start",
    "build": "CI=false react-scripts build",
    "format": "prettier --write 'src/**/*.{js,jsx}'",
    "lint": "eslint 'src/**/*.{js,jsx}'",
    "test": "npm run test:unit",
    "test:unit": "react-scripts test --watchAll=false",
    "test:e2e": "start-server-and-test start http://localhost:9300 cy:run",
    "cy:run": "cypress run",
    "cy:open": "cypress open"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "classnames": "^2.5.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.1",
    "react-router-dom": "^7.14.1",
    "redux": "^5.0.1",
    "todomvc-app-css": "^2.4.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "cypress": "^15.14.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "history": "^5.3.0",
    "jest-extended": "^7.0.0",
    "prettier": "^3.8.3",
    "react-scripts": "^5.0.1",
    "start-server-and-test": "^3.0.2"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    "last 1 chrome version",
    "last 1 firefox version"
  ]
}
